        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/overview"]
          },
          {
            "group": "Albums",
            "pages": ["api-reference/albums/get-all-albums", "api-reference/albums/get-songs-in-album"]
          },
          {
            "group": "Songs",
            "pages": ["api-reference/songs/get-all-songs", "api-reference/songs/get-song"]
          },
          {
            "group": "Lyrics",
            "pages": ["api-reference/lyrics/get-song-lyrics", "api-reference/lyrics/get-n-paragraphs"]
