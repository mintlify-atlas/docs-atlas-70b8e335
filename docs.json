{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Taylor Swift API",
  "theme": "sequoia",
  "colors": {
    "primary": "#1c1c1c",
    "light": "#8c8c86",
    "dark": "#e0e0df"
  },
  "favicon": "/favicon.jpg",
  "logo": {
    "light": "https://media.brand.dev/d90c9067-ee40-4cb4-a493-d05b67f987f9.svg",
    "dark": "https://media.brand.dev/d90c9067-ee40-4cb4-a493-d05b67f987f9.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/sarbor/taylor_swift_api"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/sarbor/taylor_swift_api"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
